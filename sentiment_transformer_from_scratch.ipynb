      "cell_type": "markdown",
      "source": [
        "## Dataset class"
      ],
      "metadata": {
        "id": "IgyEE2cE9bQq"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "class IMDBDataset(Dataset):\n",
        "  def __init__(self, hf_split, tokenizer, max_len=256):\n",
        "    self.data = hf_split\n",
        "    self.tokenizer = tokenizer\n",
        "    self.max_len = max_len\n",
        "\n",
        "  def __len__(self):\n",
        "    return len(self.data)\n",
        "\n",
        "  def __getitem__(self, idx):\n",
        "    item = self.data[idx]\n",
        "    encoded = self.tokenizer.encode(item['text'], max_len=self.max_len)\n",
        "    return {\n",
        "        \"input_ids\":      torch.tensor(encoded[\"input_ids\"], dtype=torch.long),\n",
        "        \"attention_mask\": torch.tensor(encoded[\"attention_mask\"], dtype=torch.long),\n",
        "        \"label\":          torch.tensor(item['label'], dtype=torch.long),\n",
        "    }\n"
      ],
      "metadata": {
        "id": "dv8LZeDpsxgN"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Tokenizer class\n",
        "* *tokens -> ids*"
      ],
      "metadata": {
        "id": "7sZpiOeo9ehK"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import re\n",
        "from collections import Counter\n",
        "\n",
        "class SimpleTokenizer:\n",
        "  def __init__(self, max_vocab_size=10000):\n",
        "    self.max_vocab_size = max_vocab_size\n",
        "\n",
        "    # special tokens\n",
        "    self.PAD = \"<PAD>\"\n",
        "    self.UNK = \"<UNK>\"\n",
        "\n",
        "    self.word_to_idx = {}\n",
        "    self.idx_to_word = {}\n",
        "\n",
        "  def build_vocab(self, texts):\n",
        "    counter = Counter()\n",
        "    for text in texts:\n",
        "      tokens = self.tokenize(text)\n",
        "      counter.update(tokens)\n",
        "\n",
        "    vocab = [self.PAD, self.UNK]\n",
        "    most_common = [word for word, _ in counter.most_common(self.max_vocab_size - 2)]\n",
        "    vocab += most_common\n",
        "\n",
        "    self.word_to_idx = {word: idx for idx, word in enumerate(vocab)}\n",
        "    self.idx_to_word = {idx: word for word, idx in self.word_to_idx.items()}\n",
        "\n",
        "  def tokenize(self, text):\n",
        "    text = text.lower()\n",
        "    text = re.sub(r\"([,!?,;:])\", r\"\\1\", text)\n",
        "    return text.split()\n",
        "\n",
        "  def encode(self, text, max_len=256):\n",
        "    tokens = self.tokenize(text)\n",
        "    ids = [self.word_to_idx.get(idx, self.word_to_idx[self.UNK]) for idx in tokens]\n",
        "\n",
        "    ids = ids[:max_len]\n",
        "    padding = [self.word_to_idx[self.PAD]] * (max_len - len(tokens))\n",
        "    ids = ids + padding\n",
        "\n",
        "    attention_mask = [1] * min(len(tokens), max_len) + [0] * len(padding)\n",
        "\n",
        "    return {\n",
        "        \"input_ids\": ids,\n",
        "        \"attention_mask\": attention_mask,\n",
        "    }\n",
        "\n",
        "  def decode(self, ids):\n",
        "    return \" \".join(self.idx_to_word.get(id, self.UNK) for id in ids if id != 0)"
      ],
      "metadata": {
        "id": "CZejZZcuv4a_"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## EmbeddingLayer class\n",
        "* *token_ids -> token_vectors*\n",
        "* *position_ids -> position_vectors*"
      ],
      "metadata": {
        "id": "_3aHD5BD9h5a"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "class EmbeddingLayer(nn.Module):\n",
        "  def __init__(self, vocab_size, embed_dim, max_len=256, padding_idx=0):\n",
        "    super().__init__()\n",
        "\n",
        "    # vector for each word\n",
        "    self.token_embedding = nn.Embedding(\n",
        "        vocab_size, embedding_dim=embed_dim, padding_idx=padding_idx\n",
        "    )\n",
        "    # vector fro each position\n",
        "    self.position_embedding = nn.Embedding(max_len, embed_dim)\n",
        "\n",
        "    self.dropout = nn.Dropout(0.1)\n",
        "\n",
        "  def forward(self, input_ids):\n",
        "    batch_size, seq_len = input_ids.shape\n",
        "\n",
        "    positions = torch.arange(seq_len, device = input_ids.device)\n",
        "    posiitons = positions.unsqueeze(0).expand(batch_size, -1)\n",
        "\n",
        "    x = self.token_embedding(input_ids) + self.position_embedding(positions)\n",
        "\n",
        "    return self.dropout(x)"
      ],
      "metadata": {
        "id": "miASjOBb5lX3"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## SelfAttention class\n",
        "* *vectors -> weighted vectors*"
      ],
      "metadata": {
        "id": "o9dxSafN-TVj"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "class SelfAttention(nn.Module):\n",
        "  def __init__(self, embed_dim, num_heads):\n",
        "    super().__init__()\n",
        "\n",
        "    assert embed_dim % num_heads == 0, \\\n",
        "      \"embed_dim has to be divisible by num_heads\"\n",
        "\n",
        "    self.embed_dim = embed_dim\n",
        "    self.num_heads = num_heads\n",
        "    self.head_dim  = embed_dim // num_heads\n",
        "\n",
        "    # Querry, Key, Value Matrices\n",
        "    self.W_q = nn.Linear(embed_dim, embed_dim)\n",
        "    self.W_k = nn.Linear(embed_dim, embed_dim)\n",
        "    self.W_v = nn.Linear(embed_dim, embed_dim)\n",
        "\n",
        "    # Output\n",
        "    self.W_o = nn.Linear(embed_dim, embed_dim)\n",
        "\n",
        "  def forward(self, x, attention_mask=None):\n",
        "    batch, seq_len, _ = x.shape\n",
        "\n",
        "    Q = self.W_q(x)\n",
        "    K = self.W_k(x)\n",
        "    V = self.W_v(x)\n",
        "\n",
        "    Q = Q.view(batch, seq_len, self.num_heads, self.head_dim).transpose(1, 2)\n",
        "    K = K.view(batch, seq_len, self.num_heads, self.head_dim).transpose(1, 2)\n",
        "    V = V.view(batch, seq_len, self.num_heads, self.head_dim).transpose(1, 2)\n",
        "    # [batch, num_heads, seq_len, head_dim]\n",
        "\n",
        "    scores = torch.matmul(Q, K.transpose(-2, -1))\n",
        "    scores = scores/math.sqrt(self.head_dim)\n",
        "\n",
        "    if attention_mask is not None:\n",
        "      mask = attention_mask.unsqueeze(1).unsqueeze(2)\n",
        "      scores = scores.masked_fill(mask == 0, -1e9)\n",
        "\n",
        "    weights = F.softmax(scores, dim=1)\n",
        "\n",
        "    out = torch.matmul(weights, V)\n",
        "\n",
        "    out = out.transpose(1, 2).contiguous()\n",
        "    out = out.view(batch, seq_len, self.embed_dim)\n",
        "\n",
        "    return self.W_o(out)\n",
        "\n"
      ],
      "metadata": {
        "id": "al_xO3nT948C"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## EncoderBlock class\n",
        "* *vectors -> weighted vectors (Attention + FeedForward) -> deeper vectors (\"understands\" meaning)*"
      ],
      "metadata": {
        "id": "cr8LPzyk-8Lo"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "class EncoderBlock(nn.Module):\n",
        "  def __init__(self, embed_dim, num_heads, ff_dim, dropout=0.1):\n",
        "    super().__init__()\n",
        "\n",
        "    self.attention = SelfAttention(embed_dim, num_heads)\n",
        "\n",
        "    self.feed_forward = nn.Sequential(\n",
        "        nn.Linear(embed_dim, ff_dim),\n",
        "        nn.ReLU(),\n",
        "        nn.Linear(ff_dim, embed_dim)\n",
        "    )\n",
        "\n",
        "    self.norm1 = nn.LayerNorm(embed_dim)\n",
        "    self.norm2 = nn.LayerNorm(embed_dim)\n",
        "\n",
        "    self.dropout = nn.Dropout(dropout)\n",
        "\n",
        "  def forward(self, x, attention_mask=None):\n",
        "    # Attention\n",
        "    attended = self.attention(x, attention_mask)\n",
        "\n",
        "    # ............ Residual connection\n",
        "    x = self.norm1(x + self.dropout(attended))\n",
        "\n",
        "    # Feed-Forward\n",
        "    ff_out = self.feed_forward(x)\n",
        "\n",
        "    # ............ Residual connection\n",
        "    x = self.norm2(x + self.dropout(ff_out))\n",
        "\n",
        "    return x"
      ],
      "metadata": {
        "id": "DxJHruXQS7xZ"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## SentimentTransformer class\n",
        "* *token ids -> sentiment label*\n",
        "\n",
        "```\n",
        "token ids\n",
        "   ↓  EmbeddingLayer\n",
        "vectors\n",
        "   ↓  EncoderBlock × 3\n",
        "deep context-aware vectors\n",
        "   ↓  Mean pooling\n",
        "single sentence vector\n",
        "   ↓  Classifier\n",
        "positive / negative\n",
        "```"
      ],
      "metadata": {
        "id": "X2SQlF-jAvue"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "class SentimentTransformer(nn.Module):\n",
        "  def __init__(self, vocab_size, embed_dim=128, num_heads=4,\n",
        "               ff_dim=512, num_layers=3, max_len=256,\n",
        "               num_classes=2, dropout=0.1):\n",
        "    super().__init__()\n",
        "\n",
        "    self.embedding = EmbeddingLayer(vocab_size, embed_dim, max_len)\n",
        "\n",
        "    self.encoder_blocks = nn.ModuleList([\n",
        "        EncoderBlock(embed_dim, num_heads, ff_dim, dropout)\n",
        "        for _ in range(num_layers)\n",
        "    ])\n",
        "\n",
        "    self.classifier = nn.Sequential(\n",
        "        nn.Linear(embed_dim, embed_dim // 2),\n",
        "        nn.ReLU(),\n",
        "        nn.Dropout(dropout),\n",
        "        nn.Linear(embed_dim // 2, num_classes),\n",
        "    )\n",
        "\n",
        "  def forward(self, input_ids, attention_mask=None):\n",
        "    # 1. Embedding\n",
        "    x = self.embedding(input_ids)\n",
        "\n",
        "    # 2. Encoding\n",
        "    for block in self.encoder_blocks:\n",
        "      x = block(x, attention_mask)\n",
        "\n",
        "    # 3. Mean from tokens\n",
        "    if attention_mask is not None:\n",
        "      mask = attention_mask.unsqueeze(-1).float()\n",
        "      x = (x * mask).sum(dim=1) /mask.sum(dim=1)\n",
        "    else:\n",
        "      x = x.mean(dim=1)\n",
        "\n",
        "    return self.classifier(x)\n",
        "\n"
      ],
      "metadata": {
        "id": "HdNltRrrYG5S"
      },
      "execution_count": null,
      "outputs": []
    },
    {
