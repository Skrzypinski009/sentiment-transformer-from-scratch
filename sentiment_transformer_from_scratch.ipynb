      "cell_type": "markdown",
      "source": [
        "## Using the model"
      ],
      "metadata": {
        "id": "GaLIn5JHB6M5"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Wczytaj zapisany model\n",
        "model.load_state_dict(torch.load(\"sentiment_model.pt\", map_location=device))\n",
        "model.eval()\n",
        "\n",
        "def predict(text, model, tokenizer, device):\n",
        "    encoded = tokenizer.encode(text, max_len=256)\n",
        "\n",
        "    input_ids      = torch.tensor([encoded[\"input_ids\"]],      dtype=torch.long).to(device)\n",
        "    attention_mask = torch.tensor([encoded[\"attention_mask\"]], dtype=torch.long).to(device)\n",
        "\n",
        "    with torch.no_grad():\n",
        "        logits = model(input_ids, attention_mask)  # [1, 2]\n",
        "\n",
        "    probs      = torch.softmax(logits, dim=1)[0]\n",
        "    label      = probs.argmax().item()\n",
        "    confidence = probs[label].item()\n",
        "\n",
        "    return {\n",
        "        \"label\":      \"positive\" if label == 1 else \"negative\",\n",
        "        \"confidence\": f\"{confidence:.1%}\",\n",
        "    }\n",
        "\n",
        "\n",
        "# Test\n",
        "print(predict(\"This movie was absolutely fantastic!\", model, tokenizer, device))\n",
        "\n",
        "print(predict(\"Boring and predictable. Total waste of time.\", model, tokenizer, device))\n",
      ],
